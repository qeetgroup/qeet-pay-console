# Keep the console build context lean — only source + manifests are needed.
# (The image reinstalls deps and rebuilds .output/ from scratch.)

# Dependencies + package-manager stores
node_modules
.pnpm-store

# Build output / SSR bundles (regenerated by `pnpm build`)
.output
.nitro
.tanstack
.vite
dist

# TypeScript / tooling caches
*.tsbuildinfo
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# VCS + Docker + editor/OS cruft
.git
.gitignore
Dockerfile
.dockerignore
.DS_Store
*.log

# Local env (never bake secrets into the image); .env.example is harmless but unused
.env
.env.*
!.env.example

# NOTE: src/routeTree.gen.ts is intentionally NOT ignored — it is committed and
# lets the app build without a separate codegen step (matches the sibling consoles).
